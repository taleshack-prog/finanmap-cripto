{
  "name": "finanmap-backend",
  "version": "1.0.0",
  "description": "FinanMap Cripto - API Backend",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/app.ts",
    "dev:env": "DOTENV_CONFIG_PATH=../.env ts-node-dev --respawn --transpile-only -r dotenv/config src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
