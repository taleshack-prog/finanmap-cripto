generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  nome        String
  senhaHash   String
  perfilRisco String   @default("moderado")
  saldoTotal  Decimal  @default(0) @db.Decimal(20, 8)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  portfolio   Portfolio[]
  estrategias Estrategia[]
  trades      Trade[]
}

model Portfolio {
  id           String   @id @default(uuid())
  userId       String
  exchangeName String
  ativo        String
  quantidade   Decimal  @db.Decimal(20, 8)
  precoUnitario Decimal @db.Decimal(20, 8)
  atualizadoEm DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exchangeName, ativo])
  @@index([userId])
}

model Estrategia {
  id              String   @id @default(uuid())
  userId          String
  nome            String
  tipo            String
  geracao         Int      @default(1)
  cromossomo      Json
  fitnessScore    Float    @default(0)
  retornoEsperado Float    @default(0)
  volatilidade    Float    @default(0)
  ativa           Boolean  @default(false)
  dataCriacao     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId, ativa])
}

model Trade {
  id              String   @id @default(uuid())
  userId          String
  estrategiaId    String?
  exchangeName    String
  parTrading      String
  tipo            String
  quantidade      Decimal  @db.Decimal(20, 8)
  precoEntrada    Decimal  @db.Decimal(20, 8)
  precoSaida      Decimal? @db.Decimal(20, 8)
  lucro           Decimal? @db.Decimal(20, 8)
  lucroPercentual Float?
  status          String   @default("aberto")
  timestampEntrada DateTime @default(now())
  timestampSaida   DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  estrategia Estrategia? @relation(fields: [estrategiaId], references: [id])

  botId           String?
  motivo          String?

  @@index([userId, status])
}
